 (library
  (name mlisp_test_unit)
  (preprocess (pps bisect_ppx))
  (libraries alcotest mlisp_object mlisp_object_closure mlisp_error mlisp_lexer mlisp_utils)
  (modules test_object test_lexer test_error test_object_types test_sexpr test_environment test_closure test_lexer_location test_lexer_token test_lexer_error test_tokenizer test_batch_mode)
  (wrapped false))

