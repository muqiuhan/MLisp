;; Demo of the MLisp testing framework

;; Testing module is loaded as part of stdlib
;; Functions are directly available

(println "Running MLisp Testing Framework Demo")
(println "===================================")

;; Run some tests using deftest
(println "Running individual tests:")

(println "Test 1: Addition")
(let ((result (deftest "addition" (== (+ 2 2) 4))))
  (if (car result)
    (println "  PASS")
    (println "  FAIL")))

(println "Test 2: Subtraction")
(let ((result (deftest "subtraction" (== (- 5 3) 2))))
  (if (car result)
    (println "  PASS")
    (println "  FAIL")))

(println "Test 3: List length")
(let ((result (deftest "list length" (== (length (list 1 2 3)) 3))))
  (if (car result)
    (println "  PASS")
    (println "  FAIL")))

(println "Test 4: Failing test (2 == 3)")
(let ((result (deftest "failing test" (== 2 3))))
  (if (car result)
    (println "  PASS")
    (println "  FAIL")))

(println "")
(println "Demo complete!")
