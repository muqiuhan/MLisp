;; Simple math tests for integration testing
;; Note: testing module is auto-loaded via MLISP_STDLIB_PATH

(defun factorial (n)
  (if (<= n 1) 1 (* n (factorial (- n 1)))))

(defun power (base exp)
  (if (== exp 0) 1 (* base (power base (- exp 1)))))

(module-test factorial
  (deftest "factorial of 0 is 1" (== (factorial 0) 1))
  (deftest "factorial of 1 is 1" (== (factorial 1) 1))
  (deftest "factorial of 5 is 120" (== (factorial 5) 120)))

(module-test power
  (deftest "any number to power 0 is 1" (== (power 5 0) 1))
  (deftest "2 to power 10 is 1024" (== (power 2 10) 1024)))
